rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (to find matches)
      allow read: if isAuthenticated();
      // Only the user can create/update their own profile
      allow create, update: if isOwner(userId);
      // No one can delete users for now
      allow delete: if false; 
    }
    
    // Swipes Collection
    match /swipes/{swipeId} {
        allow read: if isAuthenticated() && isOwner(resource.data.swiperId);
        allow create: if isAuthenticated() && isOwner(request.resource.data.swiperId);
    }

    // Matches Collection
    match /matches/{matchId} {
      // Allow read if user is part of the match
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      // Allow create by cloud functions usually, but for now allow if involved
      allow create: if isAuthenticated(); 
      
      // Messages Subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
